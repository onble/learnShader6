      "glsl1": {
        "vert": "\nprecision highp float;\nuniform mat4 cc_matViewProj;\nuniform mat4 cc_matWorld;\nattribute vec3 a_position;\nattribute lowp vec4 a_color;\nattribute mediump vec2 a_uv0;\nvarying mediump vec2 v_uv0;\nvarying lowp vec4 v_color;\nvarying lowp vec4 v_wp;\nvoid main() {\n  mat4 mvp;\n  mvp = cc_matViewProj;\n  v_color = a_color;\n  gl_Position = mvp * vec4(a_position, 1);\n  v_wp = cc_matWorld * vec4(a_position, 1);\n  v_uv0 = a_uv0;\n}",
        "frag": "\nprecision mediump float;\nuniform sampler2D texture;\nuniform sampler2D texture2;\nvarying mediump vec2 v_uv0;\nvarying lowp vec4 v_color;\nvarying lowp vec4 v_wp;\nfloat hash(float p) { p = fract(p * 0.011); p *= p + 7.5; p *= p + p; return fract(p); }\nfloat hash(vec2 p) {vec3 p3 = fract(vec3(p.xyx) * 0.13); p3 += dot(p3, p3.yzx + 3.333); return fract((p3.x + p3.y) * p3.z); }\nfloat noise(float x) {\n  float i = floor(x);\n  float f = fract(x);\n  float u = f * f * (3.0 - 2.0 * f);\n  return mix(hash(i), hash(i + 1.0), u);\n}\nfloat noise(vec2 x) {\n  vec2 i = floor(x);\n  vec2 f = fract(x);\n  float a = hash(i);\n  float b = hash(i + vec2(1.0, 0.0));\n  float c = hash(i + vec2(0.0, 1.0));\n  float d = hash(i + vec2(1.0, 1.0));\n  vec2 u = f * f * (3.0 - 2.0 * f);\n  return mix(a, b, u.x) + (c - a) * u.y * (1.0 - u.x) + (d - b) * u.x * u.y;\n}\nfloat noise(vec3 x) {\n  const vec3 step = vec3(110, 241, 171);\n  vec3 i = floor(x);\n  vec3 f = fract(x);\n  float n = dot(i, step);\n  vec3 u = f * f * (3.0 - 2.0 * f);\n  return mix(mix(mix(hash(n + dot(step, vec3(0, 0, 0))), hash(n + dot(step, vec3(1, 0, 0))), u.x),\n  mix(hash(n + dot(step, vec3(0, 1, 0))), hash(n + dot(step, vec3(1, 1, 0))), u.x), u.y),\n  mix(mix(hash(n + dot(step, vec3(0, 0, 1))), hash(n + dot(step, vec3(1, 0, 1))), u.x),\n  mix(hash(n + dot(step, vec3(0, 1, 1))), hash(n + dot(step, vec3(1, 1, 1))), u.x), u.y), u.z);\n}\nfloat fbm(float x) {\n  float v = 0.0;\n  float a = 0.5;\n  float shift = float(100);\n  for(int i = 0; i < 5; ++ i) {\n    v += a * noise(x);\n    x = x * 2.0 + shift;\n    a *= 0.5;\n  }\n  return v;\n}\nfloat fbm(vec2 x) {\n  float v = 0.0;\n  float a = 0.5;\n  vec2 shift = vec2(100);\n  mat2 rot = mat2(cos(0.5), sin(0.5), - sin(0.5), cos(0.50));\n  for(int i = 0; i < 5; ++ i) {\n    v += a * noise(x);\n    x = rot * x * 2.0 + shift;\n    a *= 0.5;\n  }\n  return v;\n}\nfloat fbm(vec3 x) {\n  float v = 0.0;\n  float a = 0.5;\n  vec3 shift = vec3(100);\n  for(int i = 0; i < 5; ++ i) {\n    v += a * noise(x);\n    x = x * 2.0 + shift;\n    a *= 0.5;\n  }\n  return v;\n}\nvoid main() {\n  vec2 uv = vec2(1.0 - v_uv0.x, v_uv0.y); vec2 st = uv;;\n  vec3 color = vec3(0.0);\n  vec4 tex = texture2D(texture, uv);\n  float ffbm = fbm(st * 3.0 + fbm(st * 3.0 + fbm(st * 3.0)));\n  float noiseval = noise(uv * 500.0);\n  vec3 colorhuang = vec3(1.0, 1.0, 0.0);\n  #if EFFECT1\n    color = vec3(1.0);\n  #elif EFFECT2\n    float off = 0.2 * (noiseval * 0.5 - 0.5);\n    float mul = 0.2;\n    color += texture2D(texture, uv + vec2(off, off)).xyz * mul;\n    color += texture2D(texture, uv + vec2(-off, off)).xyz * mul;\n    color += texture2D(texture, uv + vec2(off, - off)).xyz * mul;\n    color += texture2D(texture, uv + vec2(-off, - off)).xyz * mul;\n    color += texture2D(texture, uv + vec2(0.0, 0.0)).xyz * mul;\n    color = texture2D(texture, uv + vec2(off)).xyz;\n    tex.a = texture2D(texture, uv + vec2(off)).a;\n  #elif EFFECT3\n    noiseval = noise(uv * 400.0);\n    color += tex.xyz;\n    color += vec3(noiseval) * vec3(1.0, 1.0, 0.0) * 0.5;\n  #elif EFFECT4\n    noiseval = fbm(uv * 8.0);\n    color += tex.xyz;\n    color *= tex.a;\n    color = mix(color, vec3(noiseval), noiseval);\n    color = pow(color * 10.0, vec3(10.0)) * 0.00000001;\n  #elif EFFECT5\n    float off = 0.02;\n    float mul = 0.2;\n    color += texture2D(texture, uv + vec2(off, off)).xyz * mul;\n    color += texture2D(texture, uv + vec2(-off, off)).xyz * mul;\n    color += texture2D(texture, uv + vec2(off, - off)).xyz * mul;\n    color += texture2D(texture, uv + vec2(-off, - off)).xyz * mul;\n    color += texture2D(texture, uv + vec2(0.0, 0.0)).xyz * mul;\n  #elif EFFECT6\n    float sum = 0.0;\n    float off = 0.02;\n    sum += texture2D(texture, uv + vec2(off, off)).a;\n    sum += texture2D(texture, uv + vec2(-off, off)).a;\n    sum += texture2D(texture, uv + vec2(off, - off)).a;\n    sum += texture2D(texture, uv + vec2(-off, - off)).a;\n    sum += texture2D(texture, uv + vec2(0.0, 0.0)).a;\n    float checkf = 3.5;\n    float n = smoothstep(0.3, checkf * 0.5, sum) - smoothstep(checkf * 0.5, checkf, sum);\n    n = step(0.1, n);\n    color = mix(colorhuang, tex.xyz, 1.0 - n);\n  #elif EFFECT7\n    vec2 uv7 = uv * 10000.0;\n    uv7 = uv7 - mod(uv7, 300.0);\n    uv7 *= 0.0001;\n    tex = texture2D(texture, uv7);\n    color = tex.xyz;\n    float p = step(uv.y, 0.7);\n    color = mix(color, texture2D(texture, uv).xyz, p);\n    tex.a = mix(tex.a, texture2D(texture, uv).a, p);\n  #elif EFFECT8\n    color = tex.xyz;\n    color = pow(color * 2.6, vec3(10.0));\n    color *= 0.2;\n  #elif EFFECT9\n    float n = 960.0 / 640.0;\n    n = 591.0 / 200.0;\n    color = tex.xyz;\n    vec2 p = vec2(0.5, 0.8);\n    float r = 0.3;\n    vec2 off = uv - p;\n    float d = length(vec2(off.x / n, off.y));\n    d = step(d, r);\n    vec2 uv9 = p + off * 0.7;\n    vec4 tex9 = texture2D(texture, uv9);\n    color = tex9.xyz * tex9.a;\n    tex.a = max(tex.a, d);\n    color = mix(texture2D(texture, uv).xyz, color, d);\n  #elif EFFECT10\n    color = tex.xyz;\n    color -= texture2D(texture, uv - 0.001).xyz;\n    color += 0.3;\n  #elif EFFECT11\n    color = vec3(noiseval);\n    tex.a = 1.0;\n  #elif EFFECT12\n    float pixelSize = 10.0;\n    vec2 pixelCoord = uv * vec2(960.0, 640.0);\n    vec2 mosaicCoord = floor(pixelCoord / pixelSize) * pixelSize;\n    vec2 mosaicUV = mosaicCoord / vec2(960.0, 640.0);\n    tex = texture2D(texture, mosaicUV);\n    color = tex.xyz;\n  #elif EFFECT13\n  #elif EFFECT14\n  #elif EFFECT15\n  #elif EFFECT16\n  #elif EFFECT17\n  #elif EFFECT18\n  #else\n    color = vec3(0.6);\n  #endif\n  gl_FragColor = vec4(color, tex.a);\n}"
