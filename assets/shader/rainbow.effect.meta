      "glsl1": {
        "vert": "\nprecision highp float;\nuniform mat4 cc_matViewProj;\nuniform mat4 cc_matWorld;\nattribute vec3 a_position;\nattribute vec4 a_color;\nvarying vec4 v_color;\n#if USE_TEXTURE\n  attribute vec2 a_uv0;\n  varying vec2 v_uv0;\n#endif\nvoid main() {\n  vec4 pos = vec4(a_position, 1);\n  #if CC_USE_MODEL\n    pos = cc_matViewProj * cc_matWorld * pos;\n  #else\n    pos = cc_matViewProj * pos;\n  #endif\n  #if USE_TEXTURE\n    v_uv0 = a_uv0;\n  #endif\n  v_color = a_color;\n  gl_Position = pos;\n}",
        "frag": "\nprecision highp float;\n#if USE_ALPHA_TEST\n  uniform float alphaThreshold;\n#endif\nvoid ALPHA_TEST (in vec4 color) {\n  #if USE_ALPHA_TEST\n      if (color.a < alphaThreshold) discard;\n  #endif\n}\nvoid ALPHA_TEST (in float alpha) {\n  #if USE_ALPHA_TEST\n      if (alpha < alphaThreshold) discard;\n  #endif\n}\nuniform vec4 cc_time;\nvarying vec4 v_color;\n#if USE_TEXTURE\n  varying vec2 v_uv0;\n  uniform sampler2D texture;\n#endif\nvec3 rainbow(float t) {\n  float hue = mod(t, 1.0);\n  float r, g, b;\n  if (hue < 1.0 / 6.0) {\n    r = 1.0; g = hue * 6.0; b = 0.0;\n  } else if (hue < 2.0 / 6.0) {\n    r = (2.0 / 6.0 - hue) * 6.0; g = 1.0; b = 0.0;\n  } else if (hue < 3.0 / 6.0) {\n    r = 0.0; g = 1.0; b = (hue - 2.0 / 6.0) * 6.0;\n  } else if (hue < 4.0 / 6.0) {\n    r = 0.0; g = (4.0 / 6.0 - hue) * 6.0; b = 1.0;\n  } else if (hue < 5.0 / 6.0) {\n    r = (hue - 4.0 / 6.0) * 6.0; g = 0.0; b = 1.0;\n  } else {\n    r = 1.0; g = 0.0; b = (1.0 - hue) * 6.0;\n  }\n  return vec3(r, g, b);\n}\nfloat wave(vec2 uv, float time) {\n  float waveSpeed = 2.0;\n  float waveScale = 10.0;\n  float wave1 = sin(uv.x * waveScale + time * waveSpeed) * 0.5 + 0.5;\n  float wave2 = sin(uv.y * waveScale * 0.7 + time * waveSpeed * 1.3) * 0.5 + 0.5;\n  float wave3 = sin((uv.x + uv.y) * waveScale * 0.5 + time * waveSpeed * 0.8) * 0.5 + 0.5;\n  return (wave1 + wave2 + wave3) / 3.0;\n}\nvoid main() {\n  vec4 o = vec4(1, 1, 1, 1);\n  #if USE_TEXTURE\n  vec4 texture_tmp = texture2D(texture, v_uv0);\n  #if CC_USE_ALPHA_ATLAS_texture\n      texture_tmp.a *= texture2D(texture, v_uv0 + vec2(0, 0.5)).r;\n  #endif\n  #if INPUT_IS_GAMMA\n    o.rgb *= (texture_tmp.rgb * texture_tmp.rgb);\n    o.a *= texture_tmp.a;\n  #else\n    o *= texture_tmp;\n  #endif\n  #endif\n  o *= v_color;\n  vec4 texColor = o;\n  float rainbowSpeed = 1.0;\n  float saturation = 1.0;\n  float brightness = 1.0;\n  float time = cc_time.x;\n  float waveValue = wave(v_uv0, time);\n  float rainbowTime = time * rainbowSpeed;\n  vec3 rainbowColor = rainbow(waveValue + rainbowTime * 0.1);\n  vec3 finalColor = mix(texColor.rgb, rainbowColor, waveValue * 0.8);\n  float gray = dot(finalColor, vec3(0.299, 0.587, 0.114));\n  finalColor = mix(vec3(gray), finalColor, saturation);\n  finalColor *= brightness;\n  vec4 col = vec4(finalColor, texColor.a) * o;\n  ALPHA_TEST(o);\n  #if USE_BGRA\n    gl_FragColor = col.bgra;\n  #else\n    gl_FragColor = col.rgba;\n  #endif\n}"
